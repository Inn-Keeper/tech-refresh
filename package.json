{
  "name": "grip",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "dev:mobile:client": "pnpm --filter mobile dev-client",
    "dev:mobile:ios": "pnpm --filter mobile ios:sim",
    "dev:mobile:android": "pnpm --filter mobile android",
    "mobile": "pnpm dev:mobile",
    "build": "pnpm --filter web build",
    "build:mobile:ios": "pnpm --filter mobile build:ios:sim",
    "preview": "pnpm --filter web preview",
    "postinstall": "pnpm --filter mobile exec install-skia",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm --filter mobile exec tsc --noEmit && pnpm --filter web typecheck",
    "test": "pnpm --filter @tech-refresh/core test && pnpm --filter mobile test",
    "clean:ghosts": "find . -name '._*' -not -path '*/.git/*' -delete",
    "ci": "pnpm lint && pnpm test && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "form-data": "4.0.6",
      "js-yaml": "4.2.0",
      "uuid": "11.1.1"
    }
  }
}
