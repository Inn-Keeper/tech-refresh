{
  "expo": {
    "name": "Grip",
    "slug": "grip",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/brand/icon.png",
    "scheme": "grip",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/brand/icon.png",
      "bundleIdentifier": "com.innkeepers.grip"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#10131A",
        "foregroundImage": "./assets/brand/android-icon-foreground.png",
        "backgroundImage": "./assets/brand/android-icon-background.png",
        "monochromeImage": "./assets/brand/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.innkeepers.grip"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/brand/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#14171F",
          "android": {
            "image": "./assets/brand/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "innkeepers-team"
  }
}
